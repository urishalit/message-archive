{
  "hosting": {
    "public": "hosting",
    "ignore": ["firebase.json", "**/.*"],
    "headers": [
      {
        "source": "/.well-known/assetlinks.json",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/conversation/**",
        "destination": "/index.html"
      }
    ]
  }
}
